# 실제 값은 .env 에만. 이 파일은 placeholder 만.

# 앱
APP_ENV=dev                     # dev | prod
APP_PORT=8000
OWNER_LOGIN=<your-login>        # Tailscale-User-Login 값, 감사 로그/표시용

# 캐시
UPSTREAM_CACHE_TTL=10           # seconds
UPSTREAM_TIMEOUT=3              # seconds

# 백엔드 base URL (tailnet 내부). MagicDNS 안 되면 tailnet IP 직접.
REFLEXION_RONDO_BASE_URL=http://<host>.<tailnet>.ts.net:<port>
LCK_PICS_BASE_URL=http://<host>.<tailnet>.ts.net:<port>
AIRFLOW_BASE_URL=http://<host>.<tailnet>.ts.net:<port>
GRAFANA_BASE_URL=http://<host>.<tailnet>.ts.net:<port>
MINIO_BASE_URL=http://<host>.<tailnet>.ts.net:<port>
REFLEXION_DAEMON_BASE_URL=http://<host>.<tailnet>.ts.net:<port>

# per-service 토큰 (필요시. tailnet 내부면 대개 불필요)
# REFLEXION_RONDO_TOKEN=
# AIRFLOW_TOKEN=

# 개발 전용 (prod 에서 반드시 false/미설정)
DEV_FORCE_ADMIN=false
